# Shared fallback (optional)
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=
MODEL=gpt-5.4-mini

# Chat runtime config (used by /chat)
CHAT_OPENAI_API_KEY=
CHAT_OPENAI_BASE_URL=
CHAT_MODEL=gpt-5.4-mini
CHAT_API_STYLE=responses
CHAT_API_URL=http://127.0.0.1:8000/chat
CHAT_API_CONTENT_TYPE=application/json
CHAT_API_BEARER_TOKEN=

# Embedding runtime config (used by /embeddings and scripts/embedding_cli.py)
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_OPENAI_BASE_URL=https://router.tumuer.me/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_ENCODING_FORMAT=float

# Rerank runtime config (used by scripts/rerank_cli.py)
RERANK_OPENAI_API_KEY=
RERANK_OPENAI_BASE_URL=https://router.tumuer.me/v1
RERANK_MODEL=jina-reranker-v3
